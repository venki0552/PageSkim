{
  "name": "@pageskim/core",
  "version": "0.0.0",
  "description": "Pure, isomorphic conversion library for the PageSkim format: parse HTML → extract → emit .llm.md/.llm.json. Single source of truth used by the CLI, browser SDK, and playground.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tokenizer": {
      "types": "./dist/tokenizer.d.ts",
      "default": "./dist/tokenizer.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "fixtures:update": "npm run build && node scripts/update-fixtures.mjs"
  },
  "dependencies": {
    "domhandler": "^5.0.3",
    "gpt-tokenizer": "^3.0.0",
    "htmlparser2": "^10.0.0"
  }
}
