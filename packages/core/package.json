{
  "name": "@pageskim/core",
  "version": "0.1.0",
  "description": "Pure, isomorphic conversion library for the PageSkim format: parse HTML \u2192 extract \u2192 emit .llm.md/.llm.json. Single source of truth used by the CLI, browser SDK, and playground.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tokenizer": {
      "types": "./dist/tokenizer.d.ts",
      "default": "./dist/tokenizer.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "fixtures:update": "npm run build && node scripts/update-fixtures.mjs"
  },
  "dependencies": {
    "domhandler": "^5.0.3",
    "gpt-tokenizer": "^3.0.0",
    "htmlparser2": "^10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/venki0552/PageSkim.git"
  },
  "homepage": "https://github.com/venki0552/PageSkim#readme",
  "bugs": {
    "url": "https://github.com/venki0552/PageSkim/issues"
  },
  "keywords": [
    "llm",
    "agents",
    "tokens",
    "markdown",
    "llms-txt",
    "seo",
    "ai",
    "pageskim"
  ]
}
