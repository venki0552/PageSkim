{
  "name": "pageskim",
  "version": "0.0.0",
  "description": "Make any web page readable by LLMs and agents at 10-50x fewer tokens. Browser SDK (ESM + <script> builds) and CLI for the PageSkim static sibling-file format.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "pageskim": "./dist/cli.js"
  },
  "files": [
    "dist",
    "fixtures/demo.html"
  ],
  "scripts": {
    "build": "tsup",
    "test": "npm run build && vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pageskim/core": "0.0.0",
    "@pageskim/generator": "0.0.0",
    "@pageskim/validator": "0.0.0",
    "gpt-tokenizer": "^3.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0"
  }
}
