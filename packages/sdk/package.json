{
  "name": "@agentpage/sdk",
  "version": "0.0.0",
  "description": "Framework-free browser SDK for AgentPage: ESM + UMD builds of @agentpage/core for <script>/CDN use in any web page. Full API lands in Phase 4B.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agentpage/core": "0.0.0"
  }
}
