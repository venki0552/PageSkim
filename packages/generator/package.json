  "description": "CLI wrapper around @pageskim/core: pageskim generate <file|dir|-> — emits .llm.md/.llm.json sibling files.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
